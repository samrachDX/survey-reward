# ════════════════════════════════════════════════
# MongoDB Atlas
# ════════════════════════════════════════════════
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/survey_reward?retryWrites=true&w=majority

# ════════════════════════════════════════════════
# Server
# ════════════════════════════════════════════════
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend.onrender.com

# ════════════════════════════════════════════════
# Google Sheets API
# ════════════════════════════════════════════════
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_GOOGLE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ════════════════════════════════════════════════
# Cambopay / VNPay TOPUP API  ← REAL VALUES BELOW
# ════════════════════════════════════════════════
TOPUP_API_URL=https://topuptestcam.vnpaytest.vn/CambopayBank_T/CambopaySrv.asmx
TOPUP_BANK_CODE=970000
TOPUP_ACCOUNT_NO=your_account_number_here

# TOPUP_PRIVATE_KEY = Base64 of your PKCS#8 PEM private key (ready to paste into Render)
TOPUP_PRIVATE_

# ════════════════════════════════════════════════
# Token & Rate Limiting
# ════════════════════════════════════════════════
TOKEN_EXPIRY_HOURS=24
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ════════════════════════════════════════════════
# Cloudflare Turnstile CAPTCHA (optional)
# ════════════════════════════════════════════════
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
